{
  "scan": {
    "include": ["packages/*/src/**", "platform/src/**"],
    "exclude": [
      "**/node_modules/**",
      "**/dist/**",
      "**/build/**",
      "**/.sst/**",
      "landing/**",
      "clawmore/**"
    ],
    "tools": [
      "pattern-detect",
      "context-analyzer",
      "ai-signal-clarity",
      "agent-grounding",
      "testability-index",
      "doc-drift",
      "dependency-health",
      "change-amplification"
    ]
  },
  "tools": {
    "pattern-detect": {
      "minSimilarity": 0.4,
      "minLines": 4,
      "batchSize": 300,
      "approx": true,
      "minSharedTokens": 5,
      "maxCandidatesPerBlock": 500
    },
    "context-analyzer": {
      "maxContextBudget": 128000,
      "minCohesion": 0.3,
      "maxDepth": 10,
      "maxFragmentation": 0.7,
      "focus": "all",
      "includeNodeModules": false
    },
    "naming-consistency": {
      "shortWords": ["id", "db", "ui", "ai"],
      "acceptedAbbreviations": [
        "API",
        "JSON",
        "CSV",
        "HTML",
        "CSS",
        "HTTP",
        "URL",
        "SDK",
        "CLI",
        "AI",
        "ML",
        "ID",
        "DB",
        "UI",
        "config",
        "Config",
        "DEFAULT",
        "MAX",
        "MIN",
        "INIT",
        "SKILL"
      ],
      "disableChecks": []
    },
    "ai-signal-clarity": {
      "checkMagicLiterals": false,
      "checkBooleanTraps": true,
      "checkAmbiguousNames": true,
      "checkUndocumentedExports": false,
      "checkImplicitSideEffects": false,
      "checkDeepCallbacks": false
    },
    "agent-grounding": {
      "maxRecommendedDepth": 5,
      "readmeStaleDays": 30
    },
    "testability-index": {
      "minCoverageRatio": 0.3,
      "testPatterns": ["**/*.test.ts", "**/__tests__/**", "**/*.spec.ts"]
    },
    "doc-drift": {
      "maxCommits": 50,
      "staleMonths": 3
    },
    "dependency-health": {
      "trainingCutoffYear": 2023
    }
  },
  "scoring": {
    "threshold": 80,
    "showBreakdown": true,
    "profile": "default"
  },
  "output": {
    "format": "json"
  },
  "visualizer": {
    "groupingDirs": ["packages", "src", "lib"],
    "graph": {
      "maxNodes": 5000,
      "maxEdges": 10000
    }
  }
}
