{
  "name": "@aiready/ast-mcp-server",
  "version": "0.3.0",
  "description": "The AIReady AST-aware Model Context Protocol (MCP) Server. Explore and navigate multi-project TypeScript/JavaScript codebases with high precision using AST and type information.",
  "keywords": [
    "aiready",
    "mcp",
    "model-context-protocol",
    "ast",
    "typescript",
    "javascript",
    "codebase-exploration",
    "codebase-navigation",
    "ai-readiness",
    "agent-grounding",
    "ts-morph"
  ],
  "homepage": "https://github.com/getaiready/aiready-ast-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/getaiready/aiready-ast-mcp-server/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/getaiready/aiready-ast-mcp-server.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "bin": {
    "ast-mcp-server": "./dist/index.js",
    "aiready-ast-mcp": "./dist/index.js"
  },
  "files": [
    "dist",
    "smithery.yaml"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src",
    "type-check": "tsc --noEmit",
    "test-mcp": "node ../../tooling/scripts/mcp-test.js ./dist/index.js",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "@vscode/ripgrep": "^1.17.1",
    "glob": "^13.0.6",
    "ts-morph": "^25.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.1"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  }
}
