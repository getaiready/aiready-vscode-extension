{
  "name": "@aiready/monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The infrastructure for Agentic Readiness. Optimized tools for AI agents like Cursor, Windsurf, and Claude to navigate and improve codebases.",
  "keywords": [
    "AI",
    "Agentic Readiness",
    "Model Context Protocol",
    "MCP",
    "Cursor",
    "Windsurf",
    "Claude",
    "Copilot",
    "code analysis",
    "semantic duplicates",
    "context window",
    "token optimization"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prebuild": "make clean-cache",
    "build": "./scripts/build.sh build",
    "test": "./scripts/build.sh test",
    "lint": "./scripts/build.sh lint",
    "dev": "turbo run dev --filter=!@aiready/platform --concurrency 11",
    "clean": "turbo run clean && rm -rf node_modules",
    "consume-reports": "node ./scripts/consume-aiready-reports.js",
    "graph": "nx graph",
    "visualize": "node scripts/visualize.js",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "discord:setup": "tsx scripts/discord-setup.ts"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/d3": "^7.4.3",
    "@types/node": "^24.10.13",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitest/coverage-v8": "^4.1.1",
    "eslint": "^10.1.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^7.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^16.4.0",
    "npm-check-updates": "^19.6.5",
    "nx": "^22.6.1",
    "ovsx": "^0.10.9",
    "prettier": "^3.8.1",
    "semver": "^7.7.4",
    "turbo": "^2.8.20",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.1.1"
  },
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "d3": "^7.9.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
